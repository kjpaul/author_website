# Copy this file to .env (kept out of git) for local emulator runs only.
# Production uses `firebase functions:secrets:set MAILERLITE_API_KEY` plus
# the three group-ID env vars set via `firebase functions:config:set` or
# inline in the deploy environment.

MAILERLITE_API_KEY=paste-only-for-local-emulator-testing
MAILERLITE_GROUP_VOL1=
MAILERLITE_GROUP_VOL23=
MAILERLITE_GROUP_PROGRESS=
